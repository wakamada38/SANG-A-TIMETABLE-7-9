<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#1B4332">
<title>Sang'a Master Timetable</title>
<style>
  :root{
    --forest:#1B4332;
    --forest-dark:#0f2a1e;
    --forest-light:#2d6a4f;
    --gold:#d4a017;
    --gold-light:#f0c34d;
    --cream:#faf7ef;
    --line:#c9cbb8;
    --ink:#1c1c1c;
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;background:var(--cream);color:var(--ink);
    font-family:-apple-system,Segoe UI,Roboto,sans-serif;}
  body{padding-bottom:calc(24px + env(safe-area-inset-bottom));}

  header{
    background:linear-gradient(135deg,var(--forest) 0%,var(--forest-dark) 100%);
    color:#fff;padding:calc(14px + env(safe-area-inset-top)) 16px 14px;
    position:sticky;top:0;z-index:20;
    box-shadow:0 2px 8px rgba(0,0,0,.25);
  }
  header .toprow{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
  header h1{margin:0;font-size:17px;font-weight:700;letter-spacing:.3px;}
  header .sub{font-size:12px;color:var(--gold-light);margin-top:2px;font-weight:600;
    text-transform:uppercase;letter-spacing:.6px;}
  .syncbadge{
    font-size:10.5px;font-weight:700;padding:4px 9px;border-radius:12px;white-space:nowrap;
    background:rgba(255,255,255,.12);color:#e8e8e0;
  }
  .syncbadge.live{background:#1f7a3d;color:#fff;}
  .syncbadge.local{background:#8a6d00;color:#fff;}

  .controls{
    display:flex;gap:8px;padding:12px 12px 4px;flex-wrap:wrap;
  }
  .field{flex:1;min-width:120px;}
  .field label{display:block;font-size:11px;color:var(--forest-dark);font-weight:700;
    text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
  select{
    width:100%;font-size:16px;padding:10px 8px;border-radius:8px;
    border:1.5px solid var(--forest-light);background:#fff;color:var(--ink);
    font-weight:600;
  }

  .toolbar{display:flex;gap:8px;padding:10px 12px 6px;flex-wrap:wrap;}
  .btn{
    flex:1;min-width:100px;padding:10px 8px;border-radius:8px;border:none;
    font-size:13px;font-weight:700;cursor:pointer;
  }
  .btn-gold{background:var(--gold);color:var(--forest-dark);}
  .btn-outline{background:#fff;color:var(--forest);border:1.5px solid var(--forest-light);}
  .btn-danger{background:#fff;color:#8a2e2e;border:1.5px solid #c98a8a;}

  .legend{
    margin:8px 12px 4px;padding:8px 10px;background:#fff;border-radius:8px;
    border-left:4px solid var(--gold);font-size:11.5px;color:#444;line-height:1.5;
  }
  .legend b{color:var(--forest);}
  .legend.warn{border-left-color:#c0392b;color:#7a2020;font-weight:600;}

  .tablewrap{overflow-x:auto;padding:6px 8px 20px;-webkit-overflow-scrolling:touch;}
  table{border-collapse:collapse;width:100%;min-width:1180px;background:#fff;}
  th,td{border:1px solid var(--line);text-align:center;vertical-align:middle;padding:0;}
  th{background:var(--forest);color:#fff;font-size:11px;padding:6px 4px;font-weight:700;}
  th.time{font-size:10px;color:var(--gold-light);font-weight:600;}
  td.daylabel{
    background:var(--forest-light);color:#fff;font-weight:800;font-size:13px;
    writing-mode:vertical-rl;text-orientation:mixed;padding:6px 2px;white-space:nowrap;
  }
  td.gradelabel{
    background:#eef2ea;font-weight:800;color:var(--forest-dark);font-size:14px;width:34px;
  }
  td.brk{
    background:#f3e9c8;color:#7a5b00;font-weight:700;font-size:10px;
    writing-mode:vertical-rl;text-orientation:mixed;padding:4px 1px;
  }
  td.note{
    background:#fff7e0;font-weight:700;color:#8a5a00;font-size:11px;
    writing-mode:vertical-rl;text-orientation:mixed;padding:4px 2px;
  }
  td.rem{background:#eef4ee;}
  .cell{
    min-width:64px;min-height:38px;font-size:12px;padding:6px 4px;
    outline:none;cursor:text;color:#222;font-weight:600;
  }
  .cell:empty::before{content:"tap to edit";color:#b6b6a6;font-weight:400;font-style:italic;font-size:11px;}
  .cell:focus{background:#fffbe6;box-shadow:inset 0 0 0 2px var(--gold);}
  .cell.conflict{background:#ffdede;box-shadow:inset 0 0 0 2px #c0392b;color:#8a1f1f;}
  .cell.conflict:empty::before{content:"";}
  .note .cell, .brk .cell{writing-mode:horizontal-tb;}
  td.note .cell{min-width:0;}

  .toast{
    position:fixed;bottom:calc(14px + env(safe-area-inset-bottom));left:50%;
    transform:translateX(-50%) translateY(20px);background:var(--forest-dark);color:#fff;
    padding:9px 16px;border-radius:14px;font-size:12.5px;opacity:0;transition:.25s;
    pointer-events:none;z-index:50;max-width:90vw;text-align:center;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  @media print{
    header,.controls,.toolbar,.legend,.toast{display:none;}
    body{padding:0;background:#fff;}
    .tablewrap{padding:0;overflow:visible;}
    table{min-width:0;}
  }
</style>
</head>
<body>

<header>
  <div class="toprow">
    <div>
      <h1>Sang'a Comprehensive School</h1>
      <div class="sub">Master Timetable — Grade 7–9</div>
    </div>
    <div class="syncbadge" id="syncBadge">connecting…</div>
  </div>
</header>

<div class="controls">
  <div class="field">
    <label>Term</label>
    <select id="termSel">
      <option>Term 1</option>
      <option>Term 2</option>
      <option>Term 3</option>
    </select>
  </div>
  <div class="field">
    <label>Year</label>
    <select id="yearSel">
      <option>2026</option><option>2027</option><option>2028</option>
      <option>2029</option><option>2030</option>
    </select>
  </div>
</div>

<div class="toolbar">
  <button class="btn btn-gold" onclick="window.print()">Print / Export PDF</button>
  <button class="btn btn-outline" onclick="copyFromTerm()">Copy from…</button>
  <button class="btn btn-danger" onclick="resetCurrent()">Clear this term</button>
</div>

<div class="legend" id="legendMsg">
  Remedials: <b>MRN</b> 7:00–8:00, <b>LUNC</b> 1:10–2:00, <b>EVE</b> 4:00–5:00.<br>
  Tap any lesson cell to edit — changes sync live to every device open on this Term &amp; Year.
  If the same code lands in two grades at once, it's auto-moved to a free slot that day (and you'll see a "Clash fixed" note) — if there's no free slot, you'll get an alert to fix it by hand. Clashes are matched by the teacher number at the end of a code (e.g. CRE7 and PRETECH7 both flag as teacher 7), not just identical text.
</div>

<div class="tablewrap">
<table id="timetable">
  <thead>
    <tr>
      <th colspan="2"></th>
      <th class="time">7:40–8:00am</th>
      <th class="time">8:00–8:40am</th>
      <th class="time">8:40–9:20am</th>
      <th class="time">9:20–9:40am</th>
      <th class="time">9:40–10:20am</th>
      <th class="time">10:20–11:00am</th>
      <th class="time">11:00–11:30am</th>
      <th class="time">11:30am–12:10pm</th>
      <th class="time">12:10–2:00pm</th>
      <th class="time">2:00–2:40pm</th>
      <th class="time">2:40–3:20pm</th>
      <th class="time">3:20–4:00pm</th>
      <th class="time">MRN<br>7:00–8:00</th>
      <th class="time">LUNC<br>1:10–2:00</th>
      <th class="time">EVE<br>4:00–5:00</th>
      <th>Note</th>
    </tr>
  </thead>
  <tbody id="tbody"></tbody>
</table>
</div>

<div class="toast" id="toast">Saved</div>

<!-- Firebase (compat SDK — works from a single static HTML file, no build step) -->
<script src="https://www.gstatic.com/firebasejs/10.13.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.13.0/firebase-firestore-compat.js"></script>

<script>
/* =========================================================================
   FIREBASE CONFIG — replace with YOUR project's config before deploying.
   Get this from: Firebase Console → Project settings → General →
   "Your apps" → Web app (</>) → SDK setup and configuration.
   ========================================================================= */
const firebaseConfig = {
  apiKey: "AIzaSyCG8r-VyRwHCFZsuwI4cxIGaME0ttNi39I",
  authDomain: "timetable-eeb48.firebaseapp.com",
  projectId: "timetable-eeb48",
  storageBucket: "timetable-eeb48.firebasestorage.app",
  messagingSenderId: "136725919203",
  appId: "1:136725919203:web:f0e7a6fcd2cfd4ec1d5cd6"
};

let db = null;
let firebaseReady = false;
try{
  if(firebaseConfig.apiKey && firebaseConfig.apiKey !== "YOUR_API_KEY"){
    firebase.initializeApp(firebaseConfig);
    db = firebase.firestore();
    firebaseReady = true;
  }
}catch(e){
  console.error("Firebase init failed:", e);
  firebaseReady = false;
}

const DAYS = ["MON","TUE","WED","THU","FRI"];
const GRADES = [7,8,9];
const PERIODS = 8;
const REM = 3;
const DEFAULT_NOTES = {
  MON:"C & S", TUE:"G & S", WED:"G & C", THU:"Career Guidance", FRI:"PPI / General Cleanliness"
};
const PERIOD_LABELS = ["8:00–8:40am","8:40–9:20am","9:40–10:20am","10:20–11:00am","11:30am–12:10pm","2:00–2:40pm","2:40–3:20pm","3:20–4:00pm"];
const REM_LABELS = ["MRN 7:00–8:00","LUNC 1:10–2:00","EVE 4:00–5:00"];

function codeKey(str){ return (str||"").trim().toUpperCase(); }

// The trailing digits in a code are the teacher number (e.g. "CRE7" and "PRETECH7"
// are both teacher 7). Clashes are compared on that number when present, since two
// different subject prefixes can still mean the same teacher. Codes with no trailing
// number fall back to matching the whole code.
function teacherKey(str){
  const s = (str||"").trim();
  if(!s) return "";
  const m = s.match(/(\d+)\s*$/);
  return m ? m[1] : s.toUpperCase();
}

function findClashes(day, kind, idx, grade){
  const code = kind==='period' ? current[day][grade].periods[idx] : current[day][grade].rem[idx];
  const key = teacherKey(code);
  if(!key) return [];
  const others = [];
  GRADES.forEach(g=>{
    if(String(g)===String(grade)) return;
    const val = kind==='period' ? current[day][g].periods[idx] : current[day][g].rem[idx];
    if(teacherKey(val)===key) others.push(g);
  });
  return others;
}

function markSlotConflicts(day, kind, idx){
  const groups = {};
  GRADES.forEach(g=>{
    const val = kind==='period' ? current[day][g].periods[idx] : current[day][g].rem[idx];
    const key = teacherKey(val);
    if(!key) return;
    groups[key] = groups[key] || [];
    groups[key].push(g);
  });
  const clashGrades = new Set();
  Object.values(groups).forEach(arr=>{ if(arr.length>1) arr.forEach(g=>clashGrades.add(g)); });
  const attr = kind==='period' ? 'p' : 'r';
  GRADES.forEach(g=>{
    const sel = '.cell[data-day="'+day+'"][data-kind="'+kind+'"][data-'+attr+'="'+idx+'"][data-grade="'+g+'"]';
    const el = document.querySelector(sel);
    if(el) el.classList.toggle('conflict', clashGrades.has(g));
  });
}

function scanAllConflicts(){
  DAYS.forEach(day=>{
    for(let p=0;p<PERIODS;p++){ markSlotConflicts(day,'period',p); }
    for(let r=0;r<REM;r++){ markSlotConflicts(day,'rem',r); }
  });
}

function findEmptySlot(day, grade, kind){
  const arr = kind==='period' ? current[day][grade].periods : current[day][grade].rem;
  for(let i=0;i<arr.length;i++){
    if(!codeKey(arr[i])) return i;
  }
  return -1;
}

// Moves each clashing grade's colliding entry (at idx) to that grade's next free
// slot on the same day, so the newly-typed code keeps its place and nothing overlaps.
function autoResolveClash(day, kind, idx, editedGrade){
  const others = findClashes(day, kind, idx, editedGrade);
  const moves = [];
  const unresolved = [];
  others.forEach(g=>{
    const freeIdx = findEmptySlot(day, g, kind);
    if(freeIdx !== -1){
      if(kind==='period'){
        current[day][g].periods[freeIdx] = current[day][g].periods[idx];
        current[day][g].periods[idx] = "";
      } else {
        current[day][g].rem[freeIdx] = current[day][g].rem[idx];
        current[day][g].rem[idx] = "";
      }
      moves.push({grade:g, from:idx, to:freeIdx});
    } else {
      unresolved.push(g);
    }
  });
  return {moves, unresolved};
}

function blankDay(){
  const g = {};
  GRADES.forEach(gr=>{
    g[gr] = { periods: Array(PERIODS).fill(""), rem: Array(REM).fill("") };
  });
  return g;
}
function blankTimetable(){
  const t = {};
  DAYS.forEach(d=>{ t[d] = blankDay(); });
  t.notes = Object.assign({}, DEFAULT_NOTES);
  return t;
}

function storageKey(term, year){
  return "sanga_timetable_" + term.replace(/\s+/g,"") + "_" + year;
}

// ---- Local cache (used as the offline fallback / instant paint while Firestore loads) ----
function loadLocal(term, year){
  const raw = localStorage.getItem(storageKey(term, year));
  if(raw){
    try{ return JSON.parse(raw); }catch(e){}
  }
  return blankTimetable();
}
function saveLocalCache(term, year, data){
  localStorage.setItem(storageKey(term, year), JSON.stringify(data));
}

// ---- Firestore ----
function docRef(term, year){
  return db.collection('sanga_timetable').doc(storageKey(term, year));
}

function setSyncBadge(mode){
  const b = document.getElementById('syncBadge');
  if(mode==='live'){ b.textContent = '🟢 Live sync'; b.className = 'syncbadge live'; }
  else if(mode==='local'){ b.textContent = '🟡 Local only'; b.className = 'syncbadge local'; }
  else { b.textContent = '⏳ Connecting…'; b.className = 'syncbadge'; }
}

let current = null;
let unsubscribe = null;

function subscribeToCurrent(){
  const term = document.getElementById('termSel').value;
  const year = document.getElementById('yearSel').value;

  if(unsubscribe){ unsubscribe(); unsubscribe = null; }

  if(!firebaseReady){
    setSyncBadge('local');
    const legend = document.getElementById('legendMsg');
    legend.classList.add('warn');
    legend.innerHTML = 'Live sync is not connected yet — add your Firebase project config near the top of this file to enable it. Until then, changes only save on this device.';
    current = loadLocal(term, year);
    renderTable();
    return;
  }

  setSyncBadge('connecting');
  unsubscribe = docRef(term, year).onSnapshot(
    snap=>{
      current = snap.exists ? snap.data() : blankTimetable();
      saveLocalCache(term, year, current);
      renderTable();
      setSyncBadge('live');
    },
    err=>{
      console.error('Firestore listen failed:', err);
      current = loadLocal(term, year);
      renderTable();
      setSyncBadge('local');
      showToast('Offline — showing last saved copy', 2500);
    }
  );
}

function persist(data){
  const term = document.getElementById('termSel').value;
  const year = document.getElementById('yearSel').value;
  saveLocalCache(term, year, data);
  if(firebaseReady){
    docRef(term, year).set(data).catch(err=>{
      console.error('Firestore save failed:', err);
      showToast('Save failed — check connection', 2200);
    });
  }
}

function renderTable(){
  const tbody = document.getElementById('tbody');
  tbody.innerHTML = "";

  const totalRows = DAYS.length * GRADES.length;

  function periodTd(day, gr, p){
    const td = document.createElement('td');
    const div = document.createElement('div');
    div.className = 'cell';
    div.contentEditable = 'true';
    div.textContent = current[day][gr].periods[p] || "";
    div.dataset.day = day; div.dataset.grade = gr; div.dataset.p = p; div.dataset.kind='period';
    div.addEventListener('blur', onCellEdit);
    td.appendChild(div);
    return td;
  }
  function spacerTd(label){
    const td = document.createElement('td');
    td.className = 'brk';
    td.rowSpan = totalRows;
    td.textContent = label;
    return td;
  }

  let rowIndex = 0;
  DAYS.forEach(day=>{
    GRADES.forEach((gr, gi)=>{
      const tr = document.createElement('tr');
      const isFirstRow = rowIndex === 0;

      if(gi===0){
        const td = document.createElement('td');
        td.className = 'daylabel';
        td.rowSpan = 3;
        td.textContent = day;
        tr.appendChild(td);
      }

      const tdG = document.createElement('td');
      tdG.className = 'gradelabel';
      tdG.textContent = gr;
      tr.appendChild(tdG);

      if(isFirstRow) tr.appendChild(spacerTd('ASSEMBLY'));
      tr.appendChild(periodTd(day, gr, 0));
      tr.appendChild(periodTd(day, gr, 1));
      if(isFirstRow) tr.appendChild(spacerTd('BREAK'));
      tr.appendChild(periodTd(day, gr, 2));
      tr.appendChild(periodTd(day, gr, 3));
      if(isFirstRow) tr.appendChild(spacerTd('BREAK'));
      tr.appendChild(periodTd(day, gr, 4));
      if(isFirstRow) tr.appendChild(spacerTd('LUNCH'));
      tr.appendChild(periodTd(day, gr, 5));
      tr.appendChild(periodTd(day, gr, 6));
      tr.appendChild(periodTd(day, gr, 7));

      for(let r=0;r<REM;r++){
        const td = document.createElement('td');
        td.className = 'rem';
        const div = document.createElement('div');
        div.className = 'cell';
        div.contentEditable = 'true';
        div.textContent = current[day][gr].rem[r] || "";
        div.dataset.day = day; div.dataset.grade = gr; div.dataset.r = r; div.dataset.kind='rem';
        div.addEventListener('blur', onCellEdit);
        td.appendChild(div);
        tr.appendChild(td);
      }

      if(gi===0){
        const td = document.createElement('td');
        td.className = 'note';
        td.rowSpan = 3;
        const div = document.createElement('div');
        div.className = 'cell';
        div.contentEditable = 'true';
        div.textContent = current.notes[day] || "";
        div.dataset.day = day; div.dataset.kind='note';
        div.addEventListener('blur', onNoteEdit);
        td.appendChild(div);
        tr.appendChild(td);
      }

      tbody.appendChild(tr);
      rowIndex++;
    });
  });

  scanAllConflicts();
}

function onCellEdit(e){
  const el = e.target;
  const day = el.dataset.day, kind = el.dataset.kind, grade = el.dataset.grade;
  const idx = kind==='period' ? Number(el.dataset.p) : Number(el.dataset.r);
  const code = el.textContent.trim();

  if(kind==='period'){
    current[day][grade].periods[idx] = code;
  } else if(kind==='rem'){
    current[day][grade].rem[idx] = code;
  }

  const clashGrades = findClashes(day, kind, idx, grade);
  const labelArr = kind==='period' ? PERIOD_LABELS : REM_LABELS;

  if(clashGrades.length){
    const {moves, unresolved} = autoResolveClash(day, kind, idx, grade);
    persist(current);
    renderTable();

    if(moves.length){
      const summary = moves.map(m=>'Gr'+m.grade+' '+labelArr[m.from]+'→'+labelArr[m.to]).join(', ');
      showToast('Clash fixed: '+summary, 3200);
    }
    if(unresolved.length){
      alert('⚠ "'+code+'" clashes on '+day+' at '+labelArr[idx]+' with Grade '+unresolved.join(', ')+
        ', and that grade has no free slot left that day to move into.\n\nPlease resolve it manually.');
    }
  } else {
    persist(current);
    showToast('Saved');
  }
}
function onNoteEdit(e){
  const el = e.target;
  current.notes[el.dataset.day] = el.textContent.trim();
  persist(current);
  showToast('Saved');
}

let toastTimer;
function showToast(msg, ms){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), ms || 1200);
}

function resetCurrent(){
  const term = document.getElementById('termSel').value;
  const year = document.getElementById('yearSel').value;
  if(confirm('Clear all lessons for ' + term + ' ' + year + '? This cannot be undone.')){
    current = blankTimetable();
    persist(current);
    renderTable();
    showToast('Cleared');
  }
}

async function copyFromTerm(){
  const term = document.getElementById('termSel').value;
  const year = document.getElementById('yearSel').value;
  const termOpts = ["Term 1","Term 2","Term 3"];
  const yearOpts = ["2026","2027","2028","2029","2030"];
  const srcTerm = prompt('Copy FROM which term? (Term 1 / Term 2 / Term 3)', term);
  if(srcTerm===null || !termOpts.includes(srcTerm)) return;
  const srcYear = prompt('Copy FROM which year? (2026-2030)', year);
  if(srcYear===null || !yearOpts.includes(srcYear)) return;
  if(srcTerm===term && srcYear===year){ alert('That is already the current term.'); return; }

  let src;
  if(firebaseReady){
    try{
      const snap = await docRef(srcTerm, srcYear).get();
      src = snap.exists ? snap.data() : blankTimetable();
    }catch(e){
      console.error(e);
      src = loadLocal(srcTerm, srcYear);
    }
  } else {
    src = loadLocal(srcTerm, srcYear);
  }

  if(confirm('Overwrite ' + term + ' ' + year + ' with the contents of ' + srcTerm + ' ' + srcYear + '?')){
    current = JSON.parse(JSON.stringify(src));
    persist(current);
    renderTable();
    showToast('Copied');
  }
}

document.getElementById('termSel').addEventListener('change', subscribeToCurrent);
document.getElementById('yearSel').addEventListener('change', subscribeToCurrent);

// default view
document.getElementById('yearSel').value = "2026";
subscribeToCurrent();
</script>
</body>
</html>

  
